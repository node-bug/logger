{
  "name": "@nodebug/logger",
  "version": "1.1.1",
  "author": {
    "name": "Node Bug",
    "email": "nodebug@outlook.com"
  },
  "bugs": {
    "url": "https://github.com/node-bug/logger/issues"
  },
  "dependencies": {
    "winston": "^3.19.0"
  },
  "description": "Simple Winston logger helper for Node.js applications",
  "homepage": "https://github.com/node-bug/logger#readme",
  "keywords": [
    "logger",
    "node",
    "npm",
    "winston",
    "logging"
  ],
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-bug/logger.git"
  },
  "type": "module",
  "engines": {
    "node": ">=14"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint . --ext .js,.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,yaml,yml,md,sh,groovy}": [
